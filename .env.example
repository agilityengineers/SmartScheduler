# SmartScheduler Local Development Environment
# Copy this file to .env and customize as needed

# Required: Session secret (any random string)
SESSION_SECRET=your-secret-key-change-this-in-production

# Optional: Force PostgreSQL usage (leave commented for in-memory storage)
# DATABASE_URL=postgresql://user:password@localhost:5432/smartscheduler
# USE_POSTGRES=true

# Optional: Email configuration (for sending emails)
# SENDGRID_API_KEY=your-sendgrid-api-key
# FROM_EMAIL=noreply@yourdomain.com

# Optional: OAuth integrations (for calendar sync)
# Primary domain (mysmartscheduler.co) OAuth credentials
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# OUTLOOK_CLIENT_ID=your-outlook-client-id
# OUTLOOK_CLIENT_SECRET=your-outlook-client-secret

# Optional: Multi-domain OAuth support
# Alternate domain (smart-scheduler.ai) OAuth credentials
# These are used when users access via the alternate domain
# Each domain requires its own OAuth app with domain-specific redirect URIs
# GOOGLE_CLIENT_ID_ALT=your-alternate-google-client-id
# GOOGLE_CLIENT_SECRET_ALT=your-alternate-google-client-secret
# OUTLOOK_CLIENT_ID_ALT=your-alternate-outlook-client-id
# OUTLOOK_CLIENT_SECRET_ALT=your-alternate-outlook-client-secret

# Zoom OAuth (already supports multi-domain)
# ZOOM_CLIENT_ID=your-zoom-client-id
# ZOOM_CLIENT_SECRET=your-zoom-client-secret
# ZOOM_CLIENT_ID_ALT=your-alternate-zoom-client-id
# ZOOM_CLIENT_SECRET_ALT=your-alternate-zoom-client-secret

# Optional: Stripe (for subscriptions)
# STRIPE_SECRET_KEY=your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Optional: Enforce subscription/trial access on gated features (default off).
# When set to true, users without an active/trialing/past-due subscription,
# comped access, or an unexpired trial are blocked from gated actions (currently
# booking-link creation). Review the paywall policy before enabling.
# ENFORCE_SUBSCRIPTIONS=false

# Optional: Custom base URL (defaults to http://localhost:5000)
# BASE_URL=http://localhost:5000

# Optional: Encrypt stored calendar OAuth tokens / API keys at rest (AES-256-GCM).
# Must decode to 32 bytes: 64 hex chars, or base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When unset, tokens are stored as plaintext (backward compatible).
# ENCRYPTION_KEY=your-64-hex-char-key

# Optional: Max Postgres connections per instance (default 10). Keep this low
# enough that (PG_POOL_MAX * number_of_instances) stays under the database's
# connection limit on autoscale deployments.
# PG_POOL_MAX=10
